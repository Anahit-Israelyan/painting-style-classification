# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Environments ────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data (large / generated) ────────────────────────────────
# Exclude all raw and processed image data
data/raw/
data/processed/

# Exclude large binary artifacts
*.npz
*.npy

# ── Model checkpoints ───────────────────────────────────────
models/
*.pt
*.pth
*.ckpt
*.pkl

# ── Large outputs ───────────────────────────────────────────
outputs/

# Keep small CSV/TXT evaluation outputs explicitly
!outputs/*.txt
!outputs/*.csv

# ── Reports / figures ───────────────────────────────────────
# Track all committed figures; missing ones are listed in the report appendix
# reports/figures/ is no longer globally ignored — add PNGs explicitly as produced

# Keep the report document itself
!reports/report.md
!reports/*.md

# ── OS / IDE ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Do NOT ignore splits metadata (small CSVs needed for reproducibility) ──
!data/splits/split_manifest.csv
!data/splits/split_crosstab.csv
!data/splits/image_inventory.csv
!data/splits/corrupted_files.csv
!data/splits/class_to_idx.json
!data/splits/idx_to_class.json
